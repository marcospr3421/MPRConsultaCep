# Azure Configuration for Key Vault access
# Option 1: Service Principal Authentication
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_TENANT_ID=your-tenant-id-here

# Option 2: Managed Identity (set to true when running in Azure)
AZURE_USE_MSI=false

# Flask Configuration
SECRET_KEY=your-very-secret-key-here-change-this-in-production
FLASK_ENV=production

# Application Configuration
WORKERS=4
PORT=8080
HOST=0.0.0.0

# Database Configuration (if needed to override hardcoded values)
# DB_SERVER=tcp:mprsqlserver.database.windows.net,1433
# DB_NAME=mprDB02
# DB_USER=azureuser
# DB_PASSWORD=your-password-here
